# TALOS Local Worker env (Phase 1).
#
# NOTE ON PRODUCT_DATABASE_URL:
# This is a Phase 1 PLACEHOLDER. Direct laptop -> EC2 Postgres connectivity
# is NOT assumed to be solved here. EC2 Postgres is bound to 127.0.0.1 on
# the host for safety, so the worker cannot simply point at the Tailscale
# name of the EC2 box and connect.
#
# Reaching the product DB from the worker requires intentional choice,
# which Phase 1 does NOT dictate:
#   (a) Tailscale-forwarded port (tailscale serve / tsnet sidecar) into the
#       EC2 container network, OR
#   (b) A thin product-side HTTP API the worker uses instead of direct SQL, OR
#   (c) Rebinding Postgres to the Tailscale interface on EC2 (only if the
#       operator accepts the blast radius).
#
# Until one of those is explicitly configured, leave this value as a
# placeholder and treat direct worker-to-DB access as DEFERRED.
PRODUCT_DATABASE_URL=postgresql://talos_product:CHANGE_ME_STRONG_PASSWORD@PLACEHOLDER_UNTIL_TAILSCALE_PATH_CHOSEN:5432/talos_product

DIALPAD_ARCHIVE_HOST_PATH=D:/Talos_Data
DIALPAD_ARCHIVE_CONTAINER_ROOT=/mnt/dialpad_archive
DIALPAD_COMPANY_MAP_JSON={"4943523498434560":"INC"}
DIALPAD_COMPANY_FALLBACK=UNMAPPED
DIALPAD_ARCHIVE_TIMEZONE=America/New_York
DIALPAD_CLIENT_ID=
DIALPAD_CLIENT_SECRET=
DIALPAD_ACCESS_TOKEN=
DIALPAD_REFRESH_TOKEN=
DIALPAD_RECORDING_SHARE_PRIVACY=company
DIALPAD_COMPANY_ID=
DIALPAD_STATS_TIMEZONE=
DIALPAD_USER_ID=
DIALPAD_OFFICE_ID=
DIALPAD_BACKFILL_TARGET_TYPE=
DIALPAD_BACKFILL_TARGET_ID=
DIALPAD_BACKFILL_TARGET_ENTITY_ID=
DIALPAD_CATCHUP_SMTP_HOST=
DIALPAD_CATCHUP_SMTP_PORT=587
DIALPAD_CATCHUP_SMTP_USERNAME=
DIALPAD_CATCHUP_SMTP_PASSWORD=
DIALPAD_CATCHUP_SMTP_STARTTLS=true
DIALPAD_CATCHUP_SMTP_SSL=false
DIALPAD_CATCHUP_EMAIL_FROM=
DIALPAD_CATCHUP_EMAIL_TO=
DIALPAD_CATCHUP_SUBJECT_PREFIX=Dialpad Catch-Up
DIALPAD_POLL_WAIT=5
DIALPAD_POLL_MAX=8
DIALPAD_POLL_RETRY=5
ARCHIVE_SYNC_MODE=none
ARCHIVE_SYNC_RSYNC_DEST=
ARCHIVE_SYNC_SSH_KEY_PATH=
ARCHIVE_SYNC_SSH_OPTS=

LOCAL_WORKER_TOKEN=CHANGE_ME_WORKER_TOKEN
PRODUCT_WRITEBACK_URL=https://intake.taloscognitive.com/internal/worker/jobs/update
PRODUCT_WRITEBACK_TOKEN=CHANGE_ME_WRITEBACK_TOKEN
ENABLED_MODULES=transcription,archive_export,behavior_analysis,contact_engine_local,baseline_updates,deferred_backfill
LOG_LEVEL=INFO
